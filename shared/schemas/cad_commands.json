{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CAD Command Set",
  "type": "object",
  "properties": {
    "action": {
      "type": "string",
      "enum": ["load_model", "list_entities", "get_entity_properties"]
    },
    "file_path": {
      "type": "string",
      "description": "Path to the model to load"
    },
    "entity_id": {
      "type": "string",
      "description": "ID of the entity to query"
    }
  },
  "required": ["action"]
}
